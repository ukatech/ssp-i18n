    LTEXT           "Total found: [NUM]",IDC_GHOST_NUM,11,18,103,8
    LTEXT           "Total found: [NUM]",IDC_BALLOON_NUM,11,76,103,8
    LTEXT           "Total found: [NUM]",IDC_HEADLINE_NUM,11,135,103,8
    LTEXT           "Total found: [NUM]",IDC_PLUGIN_NUM,11,181,103,8
    LTEXT           "config-folder.htm",IDC_HELPFILE,181,323,51,8,NOT 
                    WS_VISIBLE
    EDITTEXT        IDC_TEMP_PATH,4,231,168,14,ES_AUTOHSCROLL
