IDD_FOLDER DIALOG DISCARDABLE  0, 0, 235, 335
STYLE WS_CHILD | WS_CAPTION
CAPTION "Folder: Configuration of data directories to read"
FONT 9, "MS Shell Dlg"
BEGIN
    PUSHBUTTON      "Edit...",IDC_GHOST_EDIT,121,15,50,14
    PUSHBUTTON      "Reload",IDC_GHOST_RELOAD,176,15,50,14
    CONTROL         "Select directory when installing",IDC_GHOST_SELECT,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,10,33,212,10
