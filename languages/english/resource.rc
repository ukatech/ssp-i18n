    PUSHBUTTON      "Reload",IDC_PLUGIN_RELOAD,176,178,50,14
    CONTROL         "Select directory when installing",IDC_PLUGIN_SELECT,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,10,196,212,10
    GROUPBOX        "Ghost",IDC_STATIC,4,6,228,56
    GROUPBOX        "Balloon",IDC_STATIC,4,64,228,56
    GROUPBOX        "Headline",IDC_STATIC,4,123,228,43
