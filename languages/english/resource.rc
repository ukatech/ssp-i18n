FONT 9, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    DEFPUSHBUTTON   "Send",IDOK,4,111,147,14
    PUSHBUTTON      "Close",IDCANCEL,163,111,32,14
    EDITTEXT        IDC_SEND_EDIT,0,0,199,89,ES_MULTILINE | ES_AUTOVSCROLL | 
                    ES_AUTOHSCROLL | ES_WANTRETURN
    CONTROL         "Parse Response",IDC_CHECK_PARSE_RESPONSE,"Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP,132,94,63,10
    CONTROL         "",IDC_SHIORI_CHARSET,"ComboBoxEx32",CBS_DROPDOWNLIST | 
                    CBS_SORT | WS_VSCROLL | WS_TABSTOP,4,92,123,234
END

IDD_STREAMINGTOOL DIALOG DISCARDABLE  0, 0, 235, 335
STYLE WS_CHILD | WS_CAPTION
CAPTION "Streaming: Configuration for use as a live streaming assistance tool"

FONT 9, "MS Shell Dlg"
BEGIN
    CONTROL         "Make character easier to capture in streaming tools",
                    IDC_WINDOW_TOPLEVEL_CHAR,"Button",BS_AUTOCHECKBOX | 
                    WS_TABSTOP,4,4,226,10
    CONTROL         "Make balloon easier to capture in streaming tools",
                    IDC_WINDOW_TOPLEVEL_BALLOON,"Button",BS_AUTOCHECKBOX | 
                    WS_TABSTOP,4,18,226,10
    CONTROL         "Enable auto lip-sync on voice detection",
                    IDC_SOUND_LEVEL_MONITOR_ENABLE,"Button",BS_AUTOCHECKBOX | 
                    WS_TABSTOP,4,36,226,10
    RTEXT           "Audio Level :",IDC_STATIC,4,80,67,8
    COMBOBOX        IDC_SOUND_LEVEL_MONITOR_DEVICE,74,50,156,132,
                    CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    CONTROL         "Slider1",IDC_SOUND_LEVEL_MONITOR_LEVEL,
                    "msctls_trackbar32",TBS_TOP | TBS_NOTICKS | WS_TABSTOP,
                    74,84,156,15
    CONTROL         "Progress1",IDC_SOUND_LEVEL_MONITOR_BAR,
                    "msctls_progress32",PBS_SMOOTH,81,73,142,10
END

IDD_VOICEAPI DIALOG DISCARDABLE  0, 0, 275, 194
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Voice synthesis settings: %s"
FONT 9, "MS Shell Dlg"
BEGIN
    DEFPUSHBUTTON   "OK",IDOK,165,176,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,221,176,50,14
    GROUPBOX        "Connection Settings",IDC_STATIC,4,98,267,71
    RTEXT           "Voice ID:",IDC_STATIC,11,60,57,8
    RTEXT           "Host/IP:",IDC_STATIC,11,113,57,8
    RTEXT           "API Key:",IDC_STATIC,11,149,57,8
    RTEXT           "Port:",IDC_STATIC,11,131,57,8
    EDITTEXT        IDC_VOICE_ID,71,57,152,14,ES_AUTOHSCROLL
    EDITTEXT        IDC_VOICE_HOST,71,110,192,14,ES_AUTOHSCROLL
    EDITTEXT        IDC_VOICE_PORT,71,128,192,14,ES_AUTOHSCROLL
    EDITTEXT        IDC_VOICE_APIKEY,71,146,192,14,ES_AUTOHSCROLL
    PUSHBUTTON      "Browse...",IDC_VOICE_VIEW,226,57,37,14
    RTEXT           "Type:",IDC_STATIC,11,39,57,8
    COMBOBOX        IDC_VOICE_TYPE,71,37,192,155,CBS_DROPDOWNLIST | CBS_SORT | 
                    WS_VSCROLL | WS_TABSTOP
    RTEXT           "Style ID:",IDC_STATIC,11,81,57,8
    EDITTEXT        IDC_VOICE_STYLEID,71,78,192,14,ES_AUTOHSCROLL
    LTEXT           "All fields are optional except API key when using cloud voice synthesis.\nPlease fill in only what is necessary and leave the rest blank.",
                    IDC_STATIC,11,9,259,24
END


