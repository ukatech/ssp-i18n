                    IDC_GHOST_SELECT_BOOT,"Button",BS_AUTOCHECKBOX | 
                    WS_TABSTOP,10,47,212,10
    PUSHBUTTON      "Edit...",IDC_BALLOON_EDIT,121,73,50,14
    PUSHBUTTON      "Reload",IDC_BALLOON_RELOAD,176,73,50,14
    CONTROL         "Select directory when installing",IDC_BALLOON_SELECT,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,10,91,212,10
    CONTROL         "Show directory configuration dialog when booting",
                    IDC_BALLOON_SELECT_BOOT,"Button",BS_AUTOCHECKBOX | 
                    WS_TABSTOP,10,105,212,10
    PUSHBUTTON      "Edit...",IDC_HEADLINE_EDIT,121,132,50,14
    PUSHBUTTON      "Reload",IDC_HEADLINE_RELOAD,176,132,50,14
    CONTROL         "Select directory when installing",IDC_HEADLINE_SELECT,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,10,150,212,10
