    EDITTEXT        IDC_NAR_PATH,4,262,168,14,ES_AUTOHSCROLL
    LTEXT           "NAR download path",IDC_NAR_PATH_STATIC,4,251,87,8
    PUSHBUTTON      "Browse",IDC_TEMP_PATH_REF,204,231,28,14
    PUSHBUTTON      "Browse",IDC_NAR_PATH_REF,204,262,28,14
    PUSHBUTTON      "Default",IDC_NAR_PATH_DEFAULT,175,262,28,14
