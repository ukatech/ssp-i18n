IDR_PICTURE_VIEWER_MENU MENU DISCARDABLE 
BEGIN
    POPUP "檔案(&F)"
    BEGIN
        MENUITEM "開啟圖片(&O)...\tCtrl+O",      PICTURE_MENU_OPEN
        MENUITEM "重新載入(&R)\tCtrl+R",             PICTURE_MENU_RELOAD
        MENUITEM "另存新檔(&S)...\tCtrl+S",         PICTURE_MENU_SAVE
    END
    POPUP "編輯(&E)"
    BEGIN
        MENUITEM "複製(&C)\tCtrl+C",               PICTURE_MENU_COPY
        MENUITEM "貼上(&V)\tCtrl+V",              PICTURE_MENU_PASTE
        MENUITEM "調整大小(&Z)...",                  PICTURE_MENU_RESIZE
        MENUITEM SEPARATOR
        MENUITEM "裁剪",                        PICTURE_MENU_TRIM
    END
    POPUP "檢視(&V)"
    BEGIN
        MENUITEM "實際大小(&A)\tCtrl+0",        PICTURE_MENU_SAME
        MENUITEM "放大(&I)\tCtrl++",            PICTURE_MENU_ZOOMIN
        MENUITEM "縮小(&O)\tCtrl+-",           PICTURE_MENU_ZOOMOUT
        MENUITEM "符合視窗(&W)",              PICTURE_MENU_FIT
        MENUITEM "設定縮放比例(&Z)...",          PICTURE_MENU_ZOOMCUSTOM
        MENUITEM SEPARATOR
        MENUITEM "上一頁",               PICTURE_MENU_PREV
        MENUITEM "下一頁",                   PICTURE_MENU_NEXT
        MENUITEM SEPARATOR
        MENUITEM "向左旋轉",                 PICTURE_MENU_ROTATE_LEFT
        MENUITEM "向右旋轉",                PICTURE_MENU_ROTATE_RIGHT
        MENUITEM "水平翻轉",             PICTURE_MENU_FLIP_H
        MENUITEM SEPARATOR
        MENUITEM "黑色背景",            PICTURE_MENU_BG_BLACK
        MENUITEM "白色背景",            PICTURE_MENU_BG_WHITE
        MENUITEM "棋盤背景",        PICTURE_MENU_BG_CHECKER
        MENUITEM SEPARATOR
        MENUITEM "使左上角顏色透明", PICTURE_MENU_COLORKEY
    END
END
 
