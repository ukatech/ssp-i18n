  POPUP "編輯(&E)"
  BEGIN
    MENUITEM "複製(&C)\tCtrl+C",  LIST_COPY
    MENUITEM "全選(&A)\tCtrl+A",  LIST_SELECTALL
    MENUITEM SEPARATOR
    MENUITEM "尋找(&F)...\tCtrl+F",  LIST_FIND
    MENUITEM "找下一個(&N)\tF3",  LIST_FIND_NEXT
  END
  POPUP "類型(&T)"
  BEGIN
    MENUITEM "人格(&G)",  LIST_TYPE_GHOST
    MENUITEM "外殼(&S)",  LIST_TYPE_SHELL
